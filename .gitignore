# === Terraform (Crucial for Security) ===
# Local .terraform folder containing binaries
.terraform/

# State files (may contain secrets in plain text)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform variables (where you might put secrets locally)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
_override.tf
_override.tf.json

# === dbt (Data Build Tool) ===
# Local logs and compiled SQL
target/
dbt_modules/
dbt_packages/
logs/

# Sensitive connection profiles (if kept in project root)
profiles.yml

# === OS & IDE ===
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# === Container & Infrastructure ===
# If you use local secrets for OpenShift testing
.secrets/
*.pem
*.key